<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="io.automotive.rn">

  <uses-permission android:name="androidx.car.app.NAVIGATION_TEMPLATES" />
  <uses-permission android:name="androidx.car.app.MAP_TEMPLATES" />
  <uses-permission android:name="androidx.car.app.ACCESS_SURFACE" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <application>
    <!--
      The `androidx.car.app.CarAppService` intent-filter (with its
      `androidx.car.app.category.*` category) is declared by the consumer,
      NOT by this library — the category depends on what kind of app the
      consumer is shipping (NAVIGATION vs POI vs IOT vs CHARGING vs WEATHER).

      Expo apps: the `react-native-automotive-expo-plugin` writes the
      intent-filter at `expo prebuild` based on its `androidAutoCategory`
      option. Bare RN apps: declare the intent-filter manually in your
      app's `AndroidManifest.xml`.

      The library-internal APP_RELOAD intent-filter stays here — it's not
      category-dependent.
    -->
    <service
      android:name=".AutomotiveService"
      android:exported="true">
      <intent-filter>
        <action android:name="io.automotive.rn.APP_RELOAD" />
      </intent-filter>
    </service>
    <meta-data
      android:name="androidx.car.app.minCarApiLevel"
      android:value="1" />

    <!-- Receives taps on notification action buttons (quick_reply + voice).
         exported=false because we fire it ourselves via PendingIntent. -->
    <receiver
      android:name="io.automotive.rn.notifications.AutomotiveNotificationsReceiver"
      android:exported="false" />
  </application>
</manifest>
